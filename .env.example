# Copy this file to .env.local for local development.
# In Vercel, add these under Project Settings → Environment Variables instead.

# Required — your Anthropic API key (get one at console.anthropic.com)
# This is used server-side only by api/claude.js — never exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional — enables response caching to cut API costs significantly.
# Get free Redis credentials at vercel.com → Storage → Marketplace → Upstash.
# If left unset, the app works fine but every request hits the AI fresh (no caching).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — enables the live Google Maps view (toggle button appears automatically).
# Get a key at console.cloud.google.com → APIs & Services → Credentials.
# Must have "Maps JavaScript API" enabled, and should be restricted by HTTP referrer
# to your deployed domain (see DEPLOY.md for exact steps).
# If left unset, the app uses its built-in lightweight map — no key required.
VITE_GOOGLE_MAPS_API_KEY=
